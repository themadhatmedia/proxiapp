# Match Flutter/AppFrameworkInfo MinimumOSVersion and Xcode IPHONEOS_DEPLOYMENT_TARGET.
#
# iOS release checklist (Runner target):
# - GoogleService-Info.plist in Runner/ (Firebase).
# - Push: Runner-Debug.entitlements (aps-environment development) vs
#   Runner-Release.entitlements (production) — Release/Profile use production for
#   TestFlight/App Store; enable Push Notifications capability in Xcode.
# - Info.plist usage strings for camera, mic, photos, location, contacts.
# - AdMob: GADApplicationIdentifier + SKAdNetworkItems in Info.plist; replace test
#   app ID with production before App Store. io.flutter.embedded_views_preview = true.
# - Stripe billing return: CFBundleURLTypes scheme proxiapp + FlutterDeepLinkingEnabled
#   false (app_links). Associated Domains applinks:myproxi.app in entitlements — enable
#   Associated Domains on App ID in Apple Developer + host apple-app-site-association.
# - Affiliate share uses share_plus (no extra plist keys).
# - permission_handler: keep GCC_PREPROCESSOR_DEFINITIONS in post_install in
#   sync with permissions you request in Dart (see permission_handler iOS setup).
# - After adding plugins (google_mobile_ads, share_plus, get_thumbnail_video,
#   in_app_purchase): run `flutter pub get && cd ios && pod install`.
# - In-App Purchase: enable capability on App ID in Apple Developer + Xcode Runner
#   target (Signing & Capabilities). Subscriptions must exist in App Store Connect.
# - Runner/PrivacyInfo.xcprivacy is bundled for App Store required-reason APIs.
platform :ios, '13.0'
use_modular_headers!

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Xcode 15+: DT_TOOLCHAIN_DIR is invalid in LIBRARY_SEARCH_PATHS etc.
      config.build_settings.each do |key, value|
        if value.is_a?(String) && value.include?('DT_TOOLCHAIN_DIR')
          config.build_settings[key] = value.gsub('DT_TOOLCHAIN_DIR', 'TOOLCHAIN_DIR')
        elsif value.is_a?(Array)
          config.build_settings[key] = value.map do |item|
            item.is_a?(String) && item.include?('DT_TOOLCHAIN_DIR') ? item.gsub('DT_TOOLCHAIN_DIR', 'TOOLCHAIN_DIR') : item
          end
        end
      end
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_CONTACTS=1',
        'PERMISSION_LOCATION=1',
        'PERMISSION_LOCATION_WHENINUSE=1',
        'PERMISSION_NOTIFICATIONS=1',
        'PERMISSION_CAMERA=1',
        'PERMISSION_MICROPHONE=1',
        'PERMISSION_PHOTOS=1',
      ]
    end
  end

  # Some pods only reference DT_TOOLCHAIN_DIR in *.xcconfig / *.sh; patch those too.
  support_root = File.join(installer.sandbox.root, 'Target Support Files')
  %w[xcconfig sh].each do |ext|
    Dir.glob(File.join(support_root, '**', "*.#{ext}")).each do |path|
      contents = File.read(path)
      next unless contents.include?('DT_TOOLCHAIN_DIR')
      File.write(path, contents.gsub('DT_TOOLCHAIN_DIR', 'TOOLCHAIN_DIR'))
    end
  end
end
